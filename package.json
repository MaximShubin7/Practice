{
  "name": "practice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "create-component": "node --experimental-modules create-component.mjs",
    "jwt-server": "node Server/index.cjs",
    "json-server": "json-server --watch src/Data/db.json --port 3002",
    "start": "concurrently \"npm run jwt-server\" \"npm run json-server\" \"npm run dev\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "classnames": "^2.5.1",
    "json-server": "^1.0.0-beta.15",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.18.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
